{
  "name": "unslop-ui",
  "version": "0.1.2",
  "description": "Catch UI slop before it ships.",
  "type": "module",
  "homepage": "https://github.com/LachyFS/unslop-ui#readme",
  "bugs": {
    "url": "https://github.com/LachyFS/unslop-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LachyFS/unslop-ui.git"
  },
  "keywords": [
    "react",
    "tailwind",
    "shadcn",
    "cli",
    "ui",
    "design-system"
  ],
  "bin": {
    "unslop-ui": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "unslop-ui": "tsx src/cli.ts"
  },
  "dependencies": {
    "@babel/parser": "^7.28.5",
    "@babel/types": "^7.28.5",
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "jiti": "^2.6.1",
    "picocolors": "^1.1.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
